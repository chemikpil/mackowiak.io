{
    "include": ["./src/**/*"],
    "exclude": [
        "node_modules",
        "**/*.spec.ts"
    ],
    "compilerOptions": {
        "target": "es2015",
        "module": "esnext", 
        "jsx": "react",
        "sourceMap": true,
        "noEmit": true,
        "importHelpers": true,
        "strict": true,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true
    }
}
